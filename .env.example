# Blog data source: "mdx" (local), "wordpress" (M1-R WP endpoint), or "hybrid"
# Default falls back to "wordpress" if unset or unrecognised.
BLOG_SOURCE=wordpress

# Homepage data source: "local" uses src/data/site-content.ts, "wordpress" uses WP REST.
# Default is "local" for the 2026-04-24 production content hotfix.
HOMEPAGE_SOURCE=local

# WordPress REST API base URL (used for homepage CMS and blog content)
WORDPRESS_API_URL=https://wordpress-l1ta-staging.up.railway.app

# Secret for /api/revalidate webhook (must match REVALIDATE_SECRET in deployment)
REVALIDATE_SECRET=replace-with-a-32-byte-random-secret
