# Blog data source: "mdx" (local), "wordpress", or "hybrid"
BLOG_SOURCE=wp

# WordPress REST API base URL (used for homepage CMS and blog content)
WORDPRESS_API_URL=https://wordpress-l1ta-staging.up.railway.app

# Secret for /api/revalidate webhook (must match REVALIDATE_SECRET in deployment)
REVALIDATE_SECRET=replace-with-a-32-byte-random-secret
